generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["mazaya"]
}

model branches {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @db.Text
  location   String?   @db.Text
  phone      String?   @db.Text
  notes      String?   @db.Text
  created_at DateTime? @default(now()) @db.Timestamptz()
  updated_at DateTime? @default(now()) @db.Timestamptz()
  users      users[]
  customers  customers[]
  orders     orders[]

  @@map("branches")
  @@schema("mazaya")
}

model users {
  id              Int                   @id @default(autoincrement())
  username        String                @unique @db.VarChar(100)
  full_name       String?               @db.VarChar(200)
  password_hash   String                @db.Text
  role            String                @default("branch") @db.VarChar(50)
  branch_id       String?               @db.Uuid
  visible_modules String[]              @default([])
  permissions     Json?                 @default("{}")
  is_active       Boolean               @default(true)
  last_login_at   DateTime?             @db.Timestamptz()
  created_at      DateTime?             @default(now()) @db.Timestamp()
  updated_at      DateTime?             @default(now()) @db.Timestamp()
  branch          branches?             @relation(fields: [branch_id], references: [id])
  audit_logs      audit_log[]
  created_orders  orders[]              @relation("orders_created_by")

  @@map("users")
  @@schema("mazaya")
}

model suppliers {
  id           String                 @id @default(uuid()) @db.Uuid
  name         String                 @db.Text
  payment_type String                 @default("نقدي") @db.Text
  phone        String?                @db.Text
  notes        String?                @db.Text
  deleted_at   DateTime?              @db.Timestamptz()
  created_at   DateTime?              @default(now()) @db.Timestamptz()
  updated_at   DateTime?              @default(now()) @db.Timestamptz()
  boards       boards_inventory[]
  accessories  accessories_inventory[]

  @@map("suppliers")
  @@schema("mazaya")
}

model customers {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @db.Text
  branch_id  String?   @db.Uuid
  phone      String?   @db.Text
  address    String?   @db.Text
  notes      String?   @db.Text
  deleted_at DateTime? @db.Timestamptz()
  created_at DateTime? @default(now()) @db.Timestamptz()
  updated_at DateTime? @default(now()) @db.Timestamptz()
  branch     branches? @relation(fields: [branch_id], references: [id])
  orders     orders[]

  @@map("customers")
  @@schema("mazaya")
}

model orders {
  id                      String                 @id @default(uuid()) @db.Uuid
  order_name              String                 @db.Text
  customer_id             String?                @db.Uuid
  branch_id               String?                @db.Uuid
  order_type              String                 @default("تصنيع جديد") @db.Text
  parent_order_id         String?                @db.Uuid
  start_date              DateTime               @default(now()) @db.Date
  end_date                DateTime?              @db.Date
  duration_days           Int?
  workers_count           Int?                   @default(0)
  status                  String                 @default("مفتوح") @db.Text
  boards_cost             Decimal                @default(0)
  accessories_cost        Decimal                @default(0)
  installation_cost       Decimal                @default(0)
  internal_transport_cost Decimal                @default(0)
  external_transport_cost Decimal                @default(0)
  factory_commission      Decimal                @default(0)
  installation_travel_days Int?                  @default(0)
  order_total             Decimal?
  notes                   String?                @db.Text
  deleted_at              DateTime?              @db.Timestamptz()
  created_by              Int?
  created_at              DateTime?              @default(now()) @db.Timestamptz()
  updated_at              DateTime?              @default(now()) @db.Timestamptz()
  customer                customers?             @relation(fields: [customer_id], references: [id])
  branch                  branches?              @relation(fields: [branch_id], references: [id])
  parent_order            orders?                @relation("ParentOrder", fields: [parent_order_id], references: [id])
  child_orders            orders[]               @relation("ParentOrder")
  creator                 users?                 @relation("orders_created_by", fields: [created_by], references: [id])
  materials               order_materials[]
  external_work           order_external_work[]
  extra_costs             order_extra_costs[]
  journal_entries         journal_entries[]

  @@map("orders")
  @@schema("mazaya")
}

model order_materials {
  id                  String   @id @default(uuid()) @db.Uuid
  order_id            String   @db.Uuid
  item_category       String   @db.Text
  item_id             String   @db.Uuid
  quantity_used       Decimal  @default(0)
  unit_price_snapshot Decimal  @default(0)
  line_total          Decimal?  @default(dbgenerated("(quantity_used * unit_price_snapshot)"))
  created_at          DateTime? @default(now()) @db.Timestamptz()
  order               orders   @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_materials")
  @@schema("mazaya")
}

model order_external_work {
  id            String    @id @default(uuid()) @db.Uuid
  order_id      String    @db.Uuid
  work_type     String    @default("أخرى") @db.Text
  contractor_id String?   @db.Uuid
  amount        Decimal   @default(0)
  notes         String?   @db.Text
  created_at    DateTime? @default(now()) @db.Timestamptz()
  order         orders    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_external_work")
  @@schema("mazaya")
}

model order_extra_costs {
  id            String    @id @default(uuid()) @db.Uuid
  order_id      String    @db.Uuid
  cost_type     String    @db.Text
  amount        Decimal   @default(0)
  notes         String?   @db.Text
  created_at    DateTime? @default(now()) @db.Timestamptz()
  order         orders    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("order_extra_costs")
  @@schema("mazaya")
}

model boards_inventory {
  id                 String              @id @default(uuid()) @db.Uuid
  item_name          String              @db.Text
  material_type      String              @default("") @db.Text
  code               String              @db.Text
  supplier_id        String?             @db.Uuid
  unit_price         Decimal             @default(0)
  unit               String              @default("") @db.Text
  quantity_in        Decimal             @default(0)
  total_price        Decimal             @default(0)
  date_added         DateTime            @default(now()) @db.Date
  linked_order_id    String?             @db.Uuid
  quantity_used      Decimal             @default(0)
  quantity_remaining Decimal             @default(0)
  used_price         Decimal?
  notes              String?             @db.Text
  deleted_at         DateTime?           @db.Timestamptz()
  created_by         Int?
  created_at         DateTime?           @default(now()) @db.Timestamptz()
  updated_at         DateTime?           @default(now()) @db.Timestamptz()
  supplier           suppliers?          @relation(fields: [supplier_id], references: [id])

  @@unique([supplier_id, code])
  @@map("boards_inventory")
  @@schema("mazaya")
}

model accessories_inventory {
  id                 String              @id @default(uuid()) @db.Uuid
  item_name          String              @db.Text
  material_type      String              @default("") @db.Text
  code               String              @db.Text
  supplier_id        String?             @db.Uuid
  unit_price         Decimal             @default(0)
  unit               String              @default("") @db.Text
  quantity_in        Decimal             @default(0)
  total_price        Decimal             @default(0)
  date_added         DateTime            @default(now()) @db.Date
  linked_order_id    String?             @db.Uuid
  quantity_used      Decimal             @default(0)
  quantity_remaining Decimal             @default(0)
  used_price         Decimal?
  notes              String?             @db.Text
  deleted_at         DateTime?           @db.Timestamptz()
  created_by         Int?
  created_at         DateTime?           @default(now()) @db.Timestamptz()
  updated_at         DateTime?           @default(now()) @db.Timestamptz()
  supplier           suppliers?          @relation(fields: [supplier_id], references: [id])

  @@unique([supplier_id, code])
  @@map("accessories_inventory")
  @@schema("mazaya")
}

model contractors {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @db.Text
  type       String    @default("أخرى") @db.Text
  phone      String?   @db.Text
  notes      String?   @db.Text
  deleted_at DateTime? @db.Timestamptz()
  created_at DateTime? @default(now()) @db.Timestamptz()
  updated_at DateTime? @default(now()) @db.Timestamptz()

  @@map("contractors")
  @@schema("mazaya")
}

model workers {
  id         String              @id @default(uuid()) @db.Uuid
  name       String              @db.Text
  phone      String?             @db.Text
  notes      String?             @db.Text
  deleted_at DateTime?           @db.Timestamptz()
  created_at DateTime?           @default(now()) @db.Timestamptz()
  updated_at DateTime?           @default(now()) @db.Timestamptz()
  expenses   overhead_expenses[]

  @@map("workers")
  @@schema("mazaya")
}

model journal_entries {
  id             String              @id @default(uuid()) @db.Uuid
  date           DateTime            @default(now()) @db.Date
  entry_type     String              @db.Text
  description    String              @default("") @db.Text
  amount         Decimal             @default(0)
  payment_method String              @default("نقدي") @db.Text
  party_id       String?             @db.Uuid
  party_type     String?             @db.Text
  order_id       String?             @db.Uuid
  is_pass_through Boolean            @default(false)
  notes          String?             @db.Text
  created_by     Int?
  created_at     DateTime?           @default(now()) @db.Timestamptz()
  updated_at     DateTime?           @default(now()) @db.Timestamptz()
  order          orders?             @relation(fields: [order_id], references: [id])
  overhead       overhead_expenses?

  @@map("journal_entries")
  @@schema("mazaya")
}

model overhead_expenses {
  id              String             @id @default(uuid()) @db.Uuid
  date            DateTime           @default(now()) @db.Date
  category        String?            @db.Text
  description     String             @db.Text
  amount          Decimal            @default(0)
  payment_method  String?            @db.Text
  notes           String?            @db.Text
  journal_entry_id String?           @unique @db.Uuid
  worker_id       String?            @db.Uuid
  created_by      Int?
  created_at      DateTime?          @default(now()) @db.Timestamptz()
  updated_at      DateTime?          @default(now()) @db.Timestamptz()
  journal_entry   journal_entries?   @relation(fields: [journal_entry_id], references: [id])
  worker          workers?           @relation(fields: [worker_id], references: [id])

  @@map("overhead_expenses")
  @@schema("mazaya")
}

model material_types {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @unique @db.Text
  category   String    @default("board") @db.Text
  is_active  Boolean   @default(true)
  sort_order Int?
  created_at DateTime? @default(now()) @db.Timestamptz()

  @@map("material_types")
  @@schema("mazaya")
}

model accessory_types {
  id         String    @id @default(uuid()) @db.Uuid
  name       String    @db.Text
  created_at DateTime? @default(now()) @db.Timestamptz()

  @@map("accessory_types")
  @@schema("mazaya")
}

model audit_log {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     Int?
  action      String   @db.VarChar(10)
  table_name  String   @db.VarChar(100)
  row_id      String   @db.Uuid
  before_json Json?
  after_json  Json?
  created_at  DateTime? @default(now()) @db.Timestamptz()
  user        users?   @relation(fields: [user_id], references: [id])

  @@map("audit_log")
  @@schema("mazaya")
}
